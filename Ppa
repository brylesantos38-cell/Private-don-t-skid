-- Entity Lifecycle Automatons (Fixed Timing System)
local function runTimedRoomRequirement(delayTime, scriptUrl)
	local lastTriggeredRoom = ReplicatedStorage.GameData.LatestRoom.Value
	while true do
		task.wait(delayTime)
		if ReplicatedStorage.GameData.LatestRoom.Value == lastTriggeredRoom then
			ReplicatedStorage.GameData.LatestRoom.Changed:Wait()
		end
		lastTriggeredRoom = ReplicatedStorage.GameData.LatestRoom.Value
		loadstring(game:HttpGet(scriptUrl))()
	end
end

